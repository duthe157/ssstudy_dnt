pipeline {
    agent any
    
    environment {
        // Docker configuration
        DOCKER_IMAGE_NAME = 'ssstudy-web-admin'
        DOCKER_REGISTRY = '' // Leave empty for Docker Hub or set your registry
        CONTAINER_NAME = 'ssstudy-admin-prod'
        CONTAINER_PORT = '80'
        HOST_PORT = '3014'
        
        // Build configuration
        NODE_VERSION = '16'
        
        // Credentials from Jenkins
        DOCKER_CREDENTIALS_ID = 'docker-hub-credentials' // Configure in Jenkins
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }
        
        stage('Load Environment Variables') {
            steps {
                script {
                    echo 'Loading environment variables from Jenkins credentials...'
                    // Load .env file from Jenkins credentials
                    withCredentials([file(credentialsId: 'web-admin-env-file', variable: 'ENV_FILE')]) {
                        sh 'cp $ENV_FILE .env'
                        echo '.env file loaded successfully'
                    }
                    
                    // Load config.js from Jenkins credentials
                    withCredentials([file(credentialsId: 'web-admin-config-js', variable: 'CONFIG_FILE')]) {
                        sh 'mkdir -p src/config'
                        sh 'cp $CONFIG_FILE src/config/config.js'
                        echo 'config.js loaded successfully'
                    }
                    
                    // Validate config.js format - ensure it uses named exports
                    sh '''#!/bin/bash
                        set -e
                        
                        echo "Checking config.js format..."
                        
                        if ! grep -q "export const baseURL" src/config/config.js; then
                            echo "⚠️  config.js does not have named exports. Converting to named exports..."
                            
                            # Use a simpler approach - just replace the entire file with the correct format
                            # The actual values should be in environment variables or use defaults
                            cat > src/config/config.js.tmp << 'CONFIGEOF'
export const webURL = 'https://admin.cms.luyenthitiendat.vn';
export const baseURL = 'https://api.luyenthitiendat.vn';
export const imgURL = 'https://media.luyenthitiendat.vn/';
CONFIGEOF
                            
                            mv -f src/config/config.js.tmp src/config/config.js
                            echo "✓ config.js converted to named exports"
                        else
                            echo "✓ config.js already has named exports"
                        fi
                        
                        # Show config.js content for verification
                        echo "=== config.js content ==="
                        cat src/config/config.js
                        echo "========================="
                    '''
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    echo 'Injecting build number into index.html for cache busting...'
                    // Generic regex to add version param to ALL local CSS files (starts with %PUBLIC_URL%)
                    sh "sed -i 's|\\(%PUBLIC_URL%.*\\.css\\)|\\1?v=${BUILD_NUMBER}|g' public/index.html"

                    echo 'Building Docker image...'
                    def imageTag = "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                    def latestTag = "${DOCKER_IMAGE_NAME}:latest"
                    
                    sh """
                        docker build \
                            --build-arg NODE_ENV=production \
                            -t ${imageTag} \
                            -t ${latestTag} \
                            -f Dockerfile.prod .
                    """
                    
                    echo "Docker image built successfully: ${imageTag}"
                }
            }
        }
        
        stage('Stop Old Container') {
            steps {
                script {
                    echo 'Stopping and removing old container if exists...'
                    sh """
                        docker stop ${CONTAINER_NAME} || true
                        docker rm ${CONTAINER_NAME} || true
                    """
                }
            }
        }
        
        stage('Deploy Container') {
            steps {
                script {
                    echo 'Deploying new container...'
                    sh """
                        docker run -d \
                            --name ${CONTAINER_NAME} \
                            --restart unless-stopped \
                            -p ${HOST_PORT}:${CONTAINER_PORT} \
                            --memory="1g" \
                            --cpus="1.0" \
                            -e NODE_ENV=production \
                            ${DOCKER_IMAGE_NAME}:latest
                    """
                    
                    echo 'Container deployed successfully'
                }
            }
        }
        
        stage('Health Check') {
            steps {
                script {
                    echo 'Performing health check...'
                    sleep(time: 10, unit: 'SECONDS')
                    
                    def containerStatus = sh(
                        script: "docker ps -f name=${CONTAINER_NAME} --format '{{.Status}}'",
                        returnStdout: true
                    ).trim()
                    
                    if (containerStatus.contains('Up')) {
                        echo "✓ Container is running: ${containerStatus}"
                    } else {
                        error "✗ Container failed to start properly"
                    }
                    
                    // Check container logs
                    echo 'Container logs:'
                    sh "docker logs --tail 50 ${CONTAINER_NAME}"
                }
            }
        }
        
        stage('Cleanup Old Images') {
            steps {
                script {
                    echo 'Cleaning up old Docker images...'
                    sh """
                        # Keep only the last 3 builds
                        docker images ${DOCKER_IMAGE_NAME} --format '{{.Tag}}' | \
                        grep -E '^[0-9]+\$' | \
                        sort -rn | \
                        tail -n +4 | \
                        xargs -I {} docker rmi ${DOCKER_IMAGE_NAME}:{} || true
                        
                        # Remove dangling images
                        docker image prune -f
                    """
                }
            }
        }
    }
    
    post {
        success {
            echo '========================================='
            echo '✓ Deployment completed successfully!'
            echo '========================================='
            echo "Container: ${CONTAINER_NAME}"
            echo "Port: ${HOST_PORT}"
            echo "Image: ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
            echo '========================================='
        }
        
        failure {
            echo '========================================='
            echo '✗ Deployment failed!'
            echo '========================================='
            script {
                // Show container logs if deployment failed
                sh "docker logs ${CONTAINER_NAME} || true"
            }
        }
        
        always {
            echo 'Cleaning up workspace...'
            // Clean up sensitive files
            sh 'rm -f .env src/config/config.js || true'
        }
    }
}
